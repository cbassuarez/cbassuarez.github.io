+        min-width: 0 !important;
+        margin: 0 !important;
+        border-left: 3px solid var(--cs-line, #070707) !important;
+        background: transparent !important;
+        box-shadow: none !important;
+        pointer-events: none !important;
+        z-index: 5 !important;
+      }
+
+      .controls.transport-strip .transport-console {
