       }
 
 
+      /* ------------------------------------------------------------------
+         Transport console module — compact always-visible diagnostic screen.
+         Right bay becomes: divider | console | reference/docs stack.
+      ------------------------------------------------------------------ */
+      .controls.transport-strip {
+        grid-template-columns:
+          7.2rem
+          minmax(15rem, 18rem)
+          minmax(6.8rem, 7.6rem)
+          minmax(7.2rem, 8.8rem)
+          1.35rem
+          minmax(18rem, 1fr)
+          minmax(10rem, 14rem) !important;
+      }
+
+      .controls.transport-strip::after {
+        content: "" !important;
+        display: block !important;
+        grid-column: 5 !important;
+        grid-row: 1 / 3 !important;
+        align-self: stretch !important;
+        justify-self: center !important;
