# this person — configuration reference
#
# The backend is the `seb-feed` Cloudflare Worker. Plain variables live in
# worker/wrangler.toml; credentials are set with `wrangler secret put`.

# Stamps each appended entry with a coarse timestamp rounded to the hour.
THIS_PERSON_SHOW_TIME=false

# Protects admin export/clear. If unset, destructive admin controls stay hidden.
THIS_PERSON_ADMIN_TOKEN=

# Google Data Portability OAuth. All are required for the public flow to run.
GOOGLE_DP_CLIENT_ID=
GOOGLE_DP_CLIENT_SECRET=
GOOGLE_DP_REDIRECT_URI=
GOOGLE_DP_STATE_SECRET=
GOOGLE_DP_TOKEN_ENCRYPTION_KEY=

# Frontend pages talk to https://seb-feed.cbassuarez.workers.dev by default.
# For local development, append ?api=http://localhost:8787 to any route.
