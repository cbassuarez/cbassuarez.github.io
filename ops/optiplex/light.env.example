# /etc/tmayd/light.env — root-owned, mode 0644.
# Copy to /etc/tmayd/light.env on the OptiPlex; safe to commit a default copy
# (no secrets — bulb is on the private LAN, discovered by broadcast).

# Filesystem watch points. Must match cloud-poller.py + print-queue paths.
TMAYD_LOCAL_QUEUE=/var/lib/tmayd/queue
TMAYD_LOCAL_PROCESSING=/var/lib/tmayd/processing
TMAYD_LOCAL_PRINTED=/var/lib/tmayd/printed
TMAYD_LOCAL_FAILED=/var/lib/tmayd/failed
TMAYD_LOCAL_STATUS=/var/lib/tmayd/status

# Cadence.
TMAYD_LIGHT_TICK_MS=250
# Heartbeat sentinel older than this → NETWORK_LOST. 3× cloud-poller's 30s
# heartbeat interval, with jitter slack.
TMAYD_LIGHT_STALE_SECONDS=90
# An edge sentinel mtime older than this is treated as historical, not a
# fresh event — protects against firing flashes on service restart.
TMAYD_LIGHT_EDGE_WINDOW_SECONDS=3
# Re-issue set_color this often in steady states (idle/printing) so the bulb
# recovers cleanly from a power-cycle without waiting for the next state
# transition.
TMAYD_LIGHT_KEEPALIVE_SECONDS=30
# A failed-file with mtime older than this is treated as historical and does
# not trip the ERROR light. Default 10 minutes — current failures only.
TMAYD_LIGHT_ERROR_WINDOW_SECONDS=600

# 1 = log commands, no bulb I/O. Use for local development.
TMAYD_LIGHT_DRY_RUN=0

# LIFX addressing.
#
# On a single-NIC host you can leave both blank — the service will discover
# the first LIFX it finds on the LAN. On a dual-homed host (e.g. optiplex
# with one NIC on the printer subnet and a USB Wi-Fi on the bulb's subnet),
# 255.255.255.255 broadcast goes out the wrong interface; pinning the MAC
# below makes the multi-interface probe filter for this specific bulb.
#
# TMAYD_LIFX_MAC alone   → probe every NIC, filter for this MAC, learn IP.
# TMAYD_LIFX_MAC + _IP   → skip probe entirely, send unicast directly.
TMAYD_LIFX_MAC=d0:73:d5:86:5b:d9
TMAYD_LIFX_IP=
# Probe listens for replies for this many seconds before giving up.
TMAYD_LIFX_PROBE_TIMEOUT_S=3.0

# HSBK quads: H (0-65535), S (0-65535), B (0-65535), K (1500-9000).
# Saturation is 65535 throughout — pure RGB, no white mixing, no temperature.
# Brightness kept moderate so the light reads as an indicator panel, not a lamp.
TMAYD_LIGHT_HSBK_IDLE=43690,65535,7000,3500
TMAYD_LIGHT_HSBK_AMBER_LO=6500,65535,8000,3500
TMAYD_LIGHT_HSBK_AMBER_HI=6500,65535,22000,3500
TMAYD_LIGHT_HSBK_AMBER_FLASH=6500,65535,40000,3500
TMAYD_LIGHT_HSBK_GREEN=21845,65535,32000,3500
TMAYD_LIGHT_HSBK_GREEN_FLASH=21845,65535,50000,3500
TMAYD_LIGHT_HSBK_RED_LO=0,65535,4000,3500
TMAYD_LIGHT_HSBK_RED_HI=0,65535,18000,3500
TMAYD_LIGHT_HSBK_RED_LOST_LO=0,65535,1500,3500
TMAYD_LIGHT_HSBK_RED_LOST_HI=0,65535,3500,3500

# Per-state durations (ms). Single fades, indicator cadence.
TMAYD_LIGHT_DUR_IDLE_ENTER=600
TMAYD_LIGHT_DUR_BREATHE=1800
TMAYD_LIGHT_DUR_BREATHE_LOST=2500
TMAYD_LIGHT_DUR_PRINTING_ENTER=400
TMAYD_LIGHT_DUR_FLASH_RISE=80
TMAYD_LIGHT_DUR_FLASH_FALL=600
TMAYD_LIGHT_DUR_PRINTED_FALL=800
