# this person — configuration reference
#
# The backend is the `seb-feed` Cloudflare Worker, so configuration is not a
# local .env file. Plain variables live in worker/wrangler.toml; tokens and
# account IDs are secrets. This file documents every setting.

# ── worker variables (worker/wrangler.toml, under [vars]) ─────────────────────

# Stamps each appended entry with a coarse timestamp rounded to the hour.
# Off by default — entries then carry no time at all.
THIS_PERSON_SHOW_TIME=false

# The optional adtech return loop. All off by default. When enabled, ad tags
# load ONLY after a participant explicitly enters the loop — never on page load.
ENABLE_ADTECH=false
ENABLE_GOOGLE_ADS=false
ENABLE_META_PIXEL=false

# ── worker secrets (set with: wrangler secret put <NAME>) ─────────────────────

# Protects the admin clear/export endpoints. If unset, the admin page exposes
# no destructive controls and those endpoints reject every request.
THIS_PERSON_ADMIN_TOKEN=

# Ad account identifiers — only needed when the return loop is enabled. Keep
# them as secrets; do not hardcode live IDs in git.
GOOGLE_ADS_ID=
GOOGLE_ADS_REMARKETING_LABEL=
META_PIXEL_ID=

# ── frontend ─────────────────────────────────────────────────────────────────
#
# The pages talk to https://seb-feed.cbassuarez.workers.dev by default. For
# local development, append ?api=http://localhost:8787 to any route, or add
# <meta name="this-person-api" content="..."> to the HTML. No build-time
# frontend environment variable is required.
#
# OCR (tesseract.js) is lazy-loaded from a CDN on demand. No key, no config.
