# /etc/tmayd/cloud.env — root-owned, mode 0600.
# Copy to /etc/tmayd/cloud.env on the OptiPlex; do NOT commit a populated copy.

TMAYD_API_BASE=https://cbassuarez.com
TMAYD_BRIDGE_ID=tmayd-bridge-001

# Shared bearer with the worker. Generate with: openssl rand -hex 32
TMAYD_BRIDGE_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING

# Local paths — already the canonical layout, do not change unless you also
# update the printer service.
TMAYD_LOCAL_QUEUE=/var/lib/tmayd/queue
TMAYD_LOCAL_PRINTED=/var/lib/tmayd/printed
TMAYD_LOCAL_FAILED=/var/lib/tmayd/failed
TMAYD_LOCAL_CLOUD_STATE=/var/lib/tmayd/cloud

# Printer reachability probe target.
TMAYD_PRINTER_HOST=192.168.50.2
TMAYD_PRINTER_PORT=9100

# Cadence.
TMAYD_HEARTBEAT_SECONDS=30
TMAYD_POLL_SECONDS=5
TMAYD_HTTP_TIMEOUT=8
