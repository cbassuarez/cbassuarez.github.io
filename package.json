{
  "name": "cbassuarez-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lens:local": "tools/chunk_surfer/diffusion_server/run-local.sh",
    "build:repl-cm": "node scripts/build-repl-cm.mjs",
    "build:corpus-motion": "node scripts/build-corpus-motion.mjs",
    "build:corpus-text-flow": "node scripts/build-corpus-text-flow.mjs",
    "build:corpus-speech-model": "node scripts/build-corpus-speech-model.mjs",
    "build:corpus-net": "node scripts/build-corpus-net.mjs",
    "build:corpus-lexicon": "node scripts/build-corpus-word-priors.mjs",
    "build:this-person": "node scripts/build-this-person.mjs",
    "test:this-person": "node scripts/test-this-person.mjs",
    "test:seb-feed": "node --test workers/seb-feed/test/*.test.js",
    "dry-run:seb-feed": "WRANGLER_LOG_PATH=.wrangler/logs ./workers/tmayd-api/node_modules/.bin/wrangler deploy --dry-run --config workers/seb-feed/wrangler.toml",
    "test:tmayd-api": "npm --prefix workers/tmayd-api test",
    "typecheck:tmayd-api": "npm --prefix workers/tmayd-api run typecheck",
    "dry-run:tmayd-api": "WRANGLER_LOG_PATH=.wrangler/logs npm --prefix workers/tmayd-api run deploy -- --dry-run",
    "test:workers": "npm run test:seb-feed && npm run test:tmayd-api && npm run typecheck:tmayd-api",
    "dry-run:workers": "npm run dry-run:seb-feed && npm run dry-run:tmayd-api",
    "ci:all": "npm run build && npm run test:this-person && npm run test:workers && npm run dry-run:workers"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "framer-motion": "^12.39.0",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@lezer/highlight": "^1.2.3",
    "@vitejs/plugin-react": "^4.3.2",
    "meshoptimizer": "^1.2.0",
    "puppeteer-core": "^25.3.0",
    "vite": "^5.4.10"
  }
}
