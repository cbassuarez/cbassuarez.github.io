+        font-weight: 900 !important;
+      }
+
+      .controls.transport-strip #reference-toggle,
+      .controls.transport-strip #docs-toggle {
+        grid-column: 7 !important;
+        justify-self: stretch !important;
+        width: 100% !important;
+        border-left: 2px solid var(--cs-line, #070707) !important;
+      }
+
+      .controls.transport-strip #reference-toggle { grid-row: 1 !important; }
+      .controls.transport-strip #docs-toggle { grid-row: 2 !important; }
+
+      @media (max-width: 74rem) {
+        .controls.transport-strip {
+          grid-template-columns: 6.8rem minmax(12rem, 1fr) 7rem 8rem !important;
+          grid-template-rows: 3.15rem 2.65rem 3.2rem 2.65rem 2.65rem !important;
+        }
+
+        .controls.transport-strip::after {
+          display: none !important;
+          content: none !important;
+        }
+
+        .controls.transport-strip .transport-console {
+          grid-column: 2 / 5 !important;
+          grid-row: 3 !important;
+        }
+
+        .controls.transport-strip #reference-toggle {
+          grid-column: 2 / 4 !important;
+          grid-row: 4 !important;
